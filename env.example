# ============================================
# GravityClaw — Agent Orchestrator Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
#
# Running with Antigravity AI Ultra for token optimization.
# Get your API keys from each service provider below.

# --- Google AI / Gemini (Agent brain) ---
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# --- GitHub ---
# https://github.com/settings/tokens (Fine-grained PAT recommended)
GITHUB_PAT=

# --- Vercel ---
# https://vercel.com/account/tokens
VERCEL_API_KEY=

# --- OpenRouter (Multi-model LLM routing) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- fal.ai (Video generation - Veo 3.1) ---
# https://fal.ai/dashboard/keys
FAL_KEY=

# --- Supabase (Database) ---
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# --- n8n (Workflow automation) ---
# Your self-hosted n8n instance API key
N8N_API_KEY=

# --- Telegram Bots (Optional - mobile notifications) ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CTO_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Firebase (Optional) ---
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=
