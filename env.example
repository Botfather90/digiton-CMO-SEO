# ============================================
# GravityClaw CMO/SEO — Agent Orchestrator
# ============================================
# Copy this file to .env and fill in your keys.
#
# ⚠️  NEVER commit .env to version control.
# ⚠️  NEVER put real API keys in this file.
#
# Each developer should create their own .env with their own keys.

# --- Google AI / Gemini (Agent brain + Lighthouse) ---
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# --- GitHub ---
# https://github.com/settings/tokens (Fine-grained PAT with repo scope)
GITHUB_PAT=

# --- GitHub Configuration (which repos to connect) ---
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-gravityclaw-repo
WEBSITE_REPO=your-website-repo
TARGET_WEBSITE_URL=https://your-website.com

# --- Vercel ---
# https://vercel.com/account/tokens
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# --- Google OAuth (for Gmail/Slack integrations) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OpenRouter (Multi-model LLM routing) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- fal.ai (Video generation) ---
# https://fal.ai/dashboard/keys
FAL_KEY=

# --- Supabase (Database) ---
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# --- n8n (Workflow automation) ---
N8N_API_KEY=
N8N_MCP_URL=

# --- X / Twitter (Social media posting) ---
X_API_KEY=
X_CLIENT_ID=

# --- Firebase (Optional) ---
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=
