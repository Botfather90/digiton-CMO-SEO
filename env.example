# ============================================
# JARVIS — Digiton Dynamics Agent Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# --- GitHub ---
GITHUB_PAT=github_pat_XXXXXXXXXXXXXXXXXXXX

# --- Vercel ---
VERCEL_API_KEY=XXXXXXXXXXXXXXXXXXXX

# --- Google AI / Gemini (bot AI brain) ---
GOOGLE_AI_API_KEY=XXXXXXXXXXXXXXXXXXXX

# --- fal.ai (Video generation - Veo 3.1 endpoint) ---
FAL_KEY=XXXXXXXXXXXXXXXXXXXX

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-XXXXXXXXXXXXXXXXXXXX

# --- Supabase ---
SUPABASE_ACCESS_TOKEN=sbp_XXXXXXXXXXXXXXXXXXXX

# --- n8n ---
N8N_API_KEY=XXXXXXXXXXXXXXXXXXXX

# --- Telegram Bots (Swarm) ---
TELEGRAM_BOT_TOKEN=XXXXXXXXXXXXXXXXXXXX
TELEGRAM_CTO_BOT_TOKEN=XXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=XXXXXXXXXXXXXXXXXXXX

# --- Firebase (if needed for client projects) ---
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=~/.config/firebase/service-account.json
