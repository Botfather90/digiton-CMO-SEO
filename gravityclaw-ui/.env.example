# GravityClaw Control Center — Environment Variables
# Copy this file to .env.local and fill in your values

# GitHub Personal Access Token (required for Files, Logs, Skills, SEO stats)
GITHUB_PAT=your_github_pat_here

# Vercel API Token (required for Apps tab — deployment monitoring)
VERCEL_API_TOKEN=your_vercel_token_here

# Google AI / Gemini API Key (required for Chat, Lighthouse, SEO stats)
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# Optional: Vercel Team ID (defaults to personal account)
# VERCEL_TEAM_ID=team_xxxxx
